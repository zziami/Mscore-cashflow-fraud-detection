def load_model(path):
    with open(path, "rb") as f:
        obj = pickle.load(f)
    return obj if isinstance(obj, dict) else {"model": obj, "scaler": None}

def get_proba(md, X_df, vlist):
    clf = md["model"]
    sc  = md.get("scaler")
    X   = sc.transform(X_df[vlist]) if sc else X_df[vlist].values
    return float(clf.predict_proba(X)[:, 1][0])

def get_top3(md, vlist):
    clf = md["model"]
    try:
        fi  = clf.feature_importances_
        idx = np.argsort(fi)[::-1][:3]
        return [(vlist[i], round(float(fi[i]), 4)) for i in idx]
    except:
        try:
            c   = np.abs(clf.coef_[0])
            idx = np.argsort(c)[::-1][:3]
            return [(vlist[i], round(float(c[i]), 4)) for i in idx]
        except:
            return []

def get_risk(p):
    for lo, hi, label, color in RISK_MAP:
        if lo <= p < hi:
            return label, color
    return "매우 높음", "#e74c3c"

